# JFrog LLM Gateway Configuration Template
# Copy this file to ~/.config/refinify/refinify-secrets (or wherever your
# refinify install expects it) and fill in your gateway API key.
#
# Source: https://github.jfrog.info/JFROG/llm-gateway/blob/master/docs/client.md
#
# refinify.lua speaks the OpenAI chat-completions protocol, so we point it at
# the gateway's OpenAI-compatible endpoint (NOT /anthropic, which is for the
# Anthropic SDK / Claude Code CLI specifically).
#
# Get your API key:
#   1. Open https://llm-gateway.jfrogdev.org/auth/sign-in and complete Okta login.
#   2. Exchange the handoff for your key (see docs/client.md "Okta: getting an API key"),
#      or ask your gateway operator for an existing sk-... key.

OPENAI_API_KEY=sk-your-gateway-key-here

# Leave OPENAI_ENDPOINT/OPENAI_API_VERSION as-is; CUSTOM_COMPLETION_URL below
# takes precedence over both in refinify.lua.
OPENAI_ENDPOINT=https://llm-gateway.jfrogdev.org
OPENAI_API_VERSION=

# Any gateway model alias works here (see models.md for the full jf-* catalogue,
# but confirm against the live catalogue with `GET /v1/models` since it can drift
# from the docs — e.g. this alias is `claude-sonnet-4.6`, not `claude-4.6-sonnet`).
OPENAI_MODEL=claude-sonnet-4.6

# The gateway's OpenAI-compatible chat completions route.
CUSTOM_COMPLETION_URL=https://llm-gateway.jfrogdev.org/v1/chat/completions

MAX_TOKENS=800
TEMPERATURE=0.7
TOP_P=0.95
FREQUENCY_PENALTY=0
PRESENCE_PENALTY=0
